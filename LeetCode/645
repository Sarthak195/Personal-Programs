class Solution {
    public int[] findErrorNums(int[] nums) {
        int[] cnt=new int[nums.length];
        for(int i:nums){
            cnt[i-1]++;
        }
        int[] res=new int[2];
        for(int j=0;j<cnt.length;j++){
            if(cnt[j]==2){
                res[0]=j+1;
            }
            if(cnt[j]==0){
                res[1]=j+1;
            }
        }
        return res;
    }
}
class Solution {
    public int countSymmetricIntegers(int low, int high) {
        int cnt=0;
        for(int i=low;i<=high;i++){
            if(i/100==0&&i/10==i%10){
                cnt++;
            }else if(i>1000&&((i%10)+((i%100)/10))==(((i%1000)/100)+(i/1000))){
                cnt++;
            }
        }
        return cnt;
    }
}
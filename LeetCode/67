class Solution:
    def addBinary(self, a: str, b: str) -> str:
        i, j = len(a)-1, len(b)-1
        carry = 0
        ans = []

        while i >= 0 or j >= 0 or carry:
            s = carry

            if i >= 0:
                s += ord(a[i]) - 48
                i -= 1
            if j >= 0:
                s += ord(b[j]) - 48
                j -= 1

            ans.append(str(s % 2))
            carry = s // 2

        return ''.join(reversed(ans))

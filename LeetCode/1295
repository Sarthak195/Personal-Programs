class Solution {
    public int findNumbers(int[] nums) {
        int res=0;
        for(int i=0;i<nums.length;i++){
            int dig=0;
            int k=nums[i];
            while(k>0){
                dig++;
                k=k/10;
            }
            if(dig%2==0){
                res++;
            }
        }
        return res;
    }
}
class Solution {
    public boolean kLengthApart(int[] nums, int k) {
        int a=0;
        for(int i=0;i<nums.length;i++){
            if(nums[i]==1&&a<k){
                a++;
            }
            if(nums[i]==1&&a>=k){
                return true;
            }
            a++;
        }
        return false;
    }
}
class Solution {
    public int dominantIndex(int[] nums) {
        int max=-1,second=-1,index=-1;
        for(int i=0;i<nums.length;i++){
            int a=nums[i];
            if(a>max){
                second=max;
                max=a;
                index=i;
            }else if(a>second){
                second=a;
            }
        }
        return max>=2*second?index:-1;
    }
}

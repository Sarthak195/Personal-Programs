class Solution {
    public int maximumDifference(int[] nums) {
        int max=-1,diff=0;
        for(int i=0;i<nums.length-1;i++){
            for(int j=i+1;j<nums.length;j++){
            diff=nums[j]-nums[i];
            max=(diff<=max||diff==0)?(max):diff;
            }
        }
        return max;
    }
}
    


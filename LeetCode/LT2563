class Solution {
    public long countFairPairs(int[] nums, int lower, int upper) {
        Arrays.sort(nums);
        long count=0;
        if(nums.length==1){
            return 0;
        }
        for(int i=0;i<nums.length;i++){
            for(int j=i+1;j<nums.length;j++){
                int val=nums[i]+nums[j];
                if(lower<=val&&val<=upper){
                    count++;
                }
            }
        }
        return count;
    }
}
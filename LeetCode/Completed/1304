class Solution {
    public int[] sumZero(int n) {
        if(n==2){
            return new int[] {1,-1};
        }
        int[] out=new int[n];
        int o=0;
            for(int i=0;i<n-1;i++){
            out[i]=i;
            o+=i;
        }
        out[n-1]=-o;
        return out;
        
    }
}
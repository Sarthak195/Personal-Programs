class Solution {
    public int canBeTypedWords(String text, String bro) {
        String[] words = text.split(" ");
        int count = 0;

        for (String word : words) {
            boolean ok = true;
            for (char c : bro.toCharArray()) {
                if (word.indexOf(c) != -1) {
                    ok = false;
                    break;
                }
            }
            if (ok) count++;
        }

        return count;
    }
}

class Solution {
    public int maximumCount(int[] nums) {
        int neg=0,pos=0;
        for(int i=0;i<nums.length;i++){
            if(nums[i]<0){
                neg++;
            }
            if(nums[i]>0){
                pos++;
            }
        }
        return pos>neg?pos:neg;
    }
}
class Solution {
    public int[] smallerNumbersThanCurrent(int[] nums) {
        int val=0;
        int num=nums.length;
        int[] res=new int[num];
        for(int i=0;i<num;i++){
            val=0;
            for(int j=0;j<num;j++){
                if(nums[j]<nums[i]){
                    val++;
                }

            }
            res[i]=val;
        }
        return res;
    }
}
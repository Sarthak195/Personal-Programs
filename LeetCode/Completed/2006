class Solution {
    public int countKDifference(int[] nums, int k) {
        int n=nums.length,temp=0;
        if(n==1){return 0;}
        for(int i=0;i<n-1;i++){
            for(int j=i+1;j<n;j++){
                if(Math.abs(nums[j]-nums[i])==k){
                    temp++;
                }
            }
        }
        return temp;
    }
}
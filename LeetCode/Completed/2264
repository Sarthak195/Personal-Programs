class Solution {
    public String largestGoodInteger(String num) {
        for(int i=999;i>0;i=i-111){
            String str = new Integer(i).toString();
            if(num.contains(str)){
                return str;
                }
            }
        if(num.contains("000")){
            return "000";
            }
        return "";
        }
    }
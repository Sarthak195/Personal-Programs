class Solution {
    public int furthestDistanceFromOrigin(String moves) {
        int a=0,b=0;
        for(int i=0;i<moves.length();i++){
            char s=moves.charAt(i);
            if(s=='L'){
                a--;
            }else if(s=='R'){
                a++;
            }else{b++;}
        }
        return Math.abs(a)+b;
    }
}
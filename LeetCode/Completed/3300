class Solution {
    public int minElement(int[] nums) {
        int a=0,num=0,min=100000;
        for(int i=0;i<nums.length;i++){
            num=nums[i];
            a=0;
            while(num>0){
                a+=num%10;
                num/=10;
            }
            min=a<min?a:min;
        }
        return min;
    }
}
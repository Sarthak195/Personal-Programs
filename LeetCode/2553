class Solution {
    public int[] separateDigits(int[] nums) {
        int n = 0, t;
        for(int i: nums){
            while(i!=0){
                n++;
                i/=10;
            }
        }
        int ans[] = new int[n];
        for(int i=nums.length-1; i>=0; i--){
            t = nums[i];
            while(t!=0){
                ans[--n] = t%10;
                t/=10;
            }
        }
        return ans;
    }
}
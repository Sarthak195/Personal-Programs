class Solution {
    public int[] rowAndMaximumOnes(int[][] mat) {
        int max=0,temp=0,ind=0;
        for(int i=0;i<mat.length;i++){
            for(int j=0;j<mat[0].length;j++){
                if(mat[i][j]==1){
                    temp++;
                    } 
                }
            if(temp>max){
                max=temp;
                ind=i;
                }
            temp=0;
            }
        return new int[] {ind,max};
        }
    }
class Solution {
    public List<Integer> intersection(int[][] nums) {
        List<Integer> res=new ArrayList<>();
        int[] cnt=new int[1002];
        int n=nums.length;
        for(int i=0;i<n;i++){
            for(int a:nums[i]){
                cnt[a]++;
            }
        }
        for(int i=0;i<1002;i++){
            if(cnt[i]==n){
                res.add(i);
            }
        }
        return res;
    }
}